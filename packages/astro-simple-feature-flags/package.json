{
  "name": "astro-simple-feature-flags",
  "version": "1.0.0",
  "description": "A simple feature flags integration for Astro. Powered by Content Layer.",
  "type": "module",
  "sideEffects": false,
  "author": {
    "name": "sushichan044",
    "url": "https://github.com/sushichan044"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sushichan044/astro-simple-feature-flags.git",
    "directory": "packages/astro-simple-feature-flags"
  },
  "bugs": {
    "url": "https://github.com/sushichan044/astro-simple-feature-flags/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "keywords": [
    "withastro",
    "astro-integration",
    "astro",
    "astrojs",
    "feature-flags"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/config/index.d.mts",
      "import": "./dist/config/index.mjs"
    },
    "./content-layer": {
      "types": "./dist/content-layer.d.mts",
      "import": "./dist/content-layer.mjs"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./internal": {
      "types": "./dist/internal/index.d.mts",
      "import": "./dist/internal/index.mjs"
    },
    "./toolbar/app": {
      "types": "./dist/toolbar/app.d.ts",
      "import": "./dist/toolbar/app.js"
    }
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "peerDependencies": {
    "astro": "^5.0.0",
    "vite": "^6.0.1"
  },
  "scripts": {
    "lint": "eslint --max-warnings 0 --fix .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "build": "tsdown"
  },
  "dependencies": {
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:build",
    "@biomejs/biome": "catalog:biome",
    "@types/node": "catalog:node",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "@virtual-live-lab/eslint-config": "catalog:eslint",
    "@virtual-live-lab/tsconfig": "catalog:typescript",
    "amaro": "1.1.1",
    "astro": "6.1.1",
    "eslint": "catalog:eslint",
    "eslint-plugin-toplevel": "1.2.0",
    "publint": "catalog:build",
    "tsdown": "catalog:build",
    "typescript": "catalog:typescript",
    "typescript-eslint": "catalog:eslint",
    "unplugin-macros": "0.19.1",
    "unplugin-unused": "catalog:build",
    "vite": "^8.0.3",
    "vitest": "catalog:test"
  }
}
